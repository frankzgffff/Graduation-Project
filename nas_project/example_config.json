{
  "seed": 42,
  "exp_name": "rle_nas_cifar10",
  "output_dir": "./outputs",
  "log_interval": 1,
  "smoke_test": false,
  "dataset": {
    "name": "cifar10",
    "root": "./data",
    "download": false,
    "image_size": 32,
    "num_classes": 10,
    "train_batch_size": 64,
    "eval_batch_size": 128,
    "num_workers": 0,
    "fake_train_size": 512,
    "fake_val_size": 256
  },
  "model": {
    "init_channels": 16,
    "num_blocks": 4,
    "stem_multiplier": 3,
    "dropout": 0.1,
    "depth_choices": [6, 8, 10],
    "width_choices": [0.75, 1.0, 1.25]
  },
  "search": {
    "population_size": 16,
    "sample_size": 4,
    "init_population_size": 8,
    "generations": 20,
    "mutation_candidates": 6,
    "candidate_eval_topk": 2,
    "use_rl": true,
    "use_evolution": true,
    "use_surrogate": true,
    "surrogate_warmup": 12,
    "surrogate_fit_interval": 5,
    "op_names": [
      "sep_conv_3x3",
      "sep_conv_5x5",
      "dil_conv_3x3",
      "max_pool_3x3",
      "avg_pool_3x3",
      "skip_connect",
      "none"
    ]
  },
  "evolution": {
    "complexity_penalty_flops": 0.015,
    "complexity_penalty_params": 0.01,
    "reward_beta": 0.05,
    "reward_cost_metric": "flops",
    "reward_cost_scale": 1.0
  },
  "train": {
    "epochs_per_eval": 5,
    "final_retrain_epochs": 150,
    "lr": 0.025,
    "final_lr": 0.025,
    "momentum": 0.9,
    "weight_decay": 0.0003,
    "grad_clip": 5.0,
    "label_smoothing": 0.0,
    "device": "cpu"
  },
  "ppo": {
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "clip_eps": 0.2,
    "entropy_coef": 0.01,
    "value_coef": 0.5,
    "policy_lr": 0.0003,
    "epochs": 4,
    "minibatch_size": 32,
    "update_interval": 4,
    "hidden_dim": 256
  },
  "predictor": {
    "hidden_dim": 128,
    "lr": 0.001,
    "epochs": 30,
    "batch_size": 32,
    "weight_decay": 0.0001
  }
}
